# Bot Configuration
BOT_USERNAME=mybot

# Slack (optional)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Microsoft Teams (optional)
# TEAMS_APP_ID=your-app-id
# TEAMS_APP_PASSWORD=your-app-password
# TEAMS_APP_TENANT_ID=your-tenant-id

# Google Chat (optional)
# GOOGLE_CHAT_CREDENTIALS={"type":"service_account",...}
# GOOGLE_CHAT_PUBSUB_TOPIC=projects/your-project/topics/your-topic
# GOOGLE_CHAT_IMPERSONATE_USER=user@domain.com

# Discord (optional)
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_PUBLIC_KEY=your-public-key
# DISCORD_APPLICATION_ID=your-application-id
# DISCORD_MENTION_ROLE_IDS=role-id-1,role-id-2

# GitHub (optional) - use PAT OR GitHub App, not both
# PAT authentication:
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# GitHub App authentication:
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----..."
# GITHUB_INSTALLATION_ID=12345678  # Optional for multi-tenant apps
# Required for either auth method:
# GITHUB_WEBHOOK_SECRET=your-webhook-secret
# GITHUB_BOT_USERNAME=my-bot  # or my-bot[bot] for GitHub Apps

# Linear (optional) - use API key OR OAuth app, not both
# API key authentication (simplest):
# LINEAR_API_KEY=lin_api_xxxxxxxxxxxx
# OR OAuth app (client credentials - recommended for apps):
# LINEAR_CLIENT_ID=your-client-id
# LINEAR_CLIENT_SECRET=your-client-secret
# Required for either auth method:
# LINEAR_WEBHOOK_SECRET=your-webhook-secret
# LINEAR_BOT_USERNAME=my-bot

# Redis (for production state persistence)
# REDIS_URL=redis://localhost:6379

# Recording (optional, for replay testing)
# RECORDING_ENABLED=true
# RECORDING_SESSION_ID=session-custom-id

# Discord Gateway (optional, for cron-based gateway listener)
# CRON_SECRET=your-cron-secret
# VERCEL_AUTOMATION_BYPASS_SECRET=your-bypass-secret
