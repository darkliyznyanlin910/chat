# ── Shared (required in both modes) ─────────────────────────────────
FACEBOOK_APP_ID=your-app-id
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ── Mode ────────────────────────────────────────────────────────────
# "single" (default) — one phone number, credentials from env vars
# "multi" — multiple numbers, credentials stored in state adapter
WHATSAPP_MODE=single

# ── Single-number mode only ─────────────────────────────────────────
# Not needed in multi-number mode — credentials come from OAuth flow
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ── Optional ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
BOT_USERNAME=whatsapp-bot
