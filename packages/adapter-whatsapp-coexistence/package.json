{
  "name": "@chat-adapter/whatsapp-coexistence",
  "version": "0.1.0",
  "description": "WhatsApp coexistence adapter for chat - supports simultaneous Business App and Cloud API usage",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chat-adapter/shared": "workspace:*",
    "@chat-adapter/whatsapp": "workspace:*",
    "chat": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vercel/chat.git",
    "directory": "packages/adapter-whatsapp-coexistence"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat",
    "whatsapp",
    "coexistence",
    "bot",
    "adapter",
    "messaging",
    "meta",
    "cloud-api",
    "business-app"
  ],
  "license": "MIT"
}
